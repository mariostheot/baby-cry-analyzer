<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Needed on Android 13+ to remind the parent, a few minutes after a cry, to confirm
         the real reason (once they've figured out why the baby cried). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- The "why did it cry?" reminder must fire a few minutes later even while the phone is
         idle. WorkManager gets deferred by Doze/battery saving (can be tens of minutes late),
         so we use an exact alarm. USE_EXACT_ALARM is auto-granted (33+); SCHEDULE_EXACT_ALARM
         covers 31-32 where it is granted on install. -->
    <uses-permission
        android:name="android.permission.SCHEDULE_EXACT_ALARM"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <!-- We only record from the microphone; a mic is required for the core feature. -->
    <uses-feature
        android:name="android.hardware.microphone"
        android:required="true" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BabyCryAnalyzer.Splash">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.BabyCryAnalyzer.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Fires the delayed "why did it cry?" reminder posted by an exact alarm. -->
        <receiver
            android:name=".notify.ConfirmAlarmReceiver"
            android:exported="false" />

        <!-- Fires the "feeding time is near" reminder posted by an exact alarm. -->
        <receiver
            android:name=".notify.FeedAlarmReceiver"
            android:exported="false" />

        <!-- Fires the twice-daily tummy-time reminders posted by exact alarms. -->
        <receiver
            android:name=".notify.TummyAlarmReceiver"
            android:exported="false" />
    </application>

</manifest>
